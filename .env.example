# ════════════════════════════════════════════════════════════════
# AIscentra backend — environment template
# Copy this file to .env and fill in real values. Never commit .env.
# ════════════════════════════════════════════════════════════════

# Supabase project — Settings -> API in your Supabase dashboard
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key (NOT the anon key) — required because this backend
# writes to research_sources, articles, ai_runs with elevated trust,
# bypassing RLS. Settings -> API -> service_role key.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# Which models each role calls. Any OpenRouter model slug works.
# Using free-tier models by default (cost: $0) — names ending in
# ":free" on OpenRouter. Quality is lower than paid models like
# Claude/GPT, but no usage charges apply. Swap to a paid model
# anytime by changing these values.
RESEARCH_MODEL=meta-llama/llama-3.3-70b-instruct:free
EDITOR_MODEL=meta-llama/llama-3.3-70b-instruct:free
ASSISTANT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Local server port
PORT=3001
